---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="diagram-frame">
  <div class="diagram-inline" role="img" aria-label={alt} set:html={src} />
  {caption && <figcaption class="diagram-caption">{caption}</figcaption>}
</figure>

<style>
  .diagram-inline :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--at-radius, 14px);
  }
</style>
